    -- Casts and renames raw columns. Nothing fancy — just clean types.
WITH source AS (
    SELECT * FROM raw.weather_daily
)

SELECT
    date                                    AS weather_date,
    temp_max                                AS temperature_max_c,
    temp_min                                AS temperature_min_c,
